---
import { NAV_ITEMS } from "./nav.ts";

// The one shared shell (#203, per the ratified Sub 1 decision doc on #202):
// head meta with the prop fan-out, the canonical nav, the constant footer.
// Every page renders through it since Sub 8 (#254). The Running Head (#268)
// replaced the centered masthead with the folio page-header form and moved
// the <title> into the layout, computed from `room`, so title drift across
// pages is structurally impossible.
interface Props {
  /**
   * The page's name on the running head's right side, and the computed
   * <title> ("The Print Room · Vellum"). Absent on home ALONE, whose title
   * stays the atelier's own line. The atlas keeps its in-fiction title
   * exception outside this layout entirely.
   */
  room?: string;
  /**
   * The og twins' punctuation-normalized room, only when it differs from
   * `room` (the Q & A page's &-form split): og:title AND twitter:title take
   * `${ogRoom} · Vellum` instead of the computed title.
   */
  ogRoom?: string;
  /** The name=description search snippet; also the og twins' default. */
  description: string;
  /**
   * Fans out to og:description AND twitter:description. Only for a page whose
   * card copy is shorter than its search snippet (seed-of-the-day); defaults
   * to description, exactly parallel to the room/ogRoom split.
   */
  ogDescription?: string;
  /** Root-absolute trailing-slash route ("/", "/faq/"): og:url + aria-current. */
  path: string;
  /** The flourish line under the room name (under the wordmark alone on home). */
  tagline: string;
}

const { room, ogRoom, description, ogDescription, path, tagline } = Astro.props;

if (!/^\/([a-z0-9-]+\/)*$/.test(path)) {
  throw new Error(`BaseLayout path must be root-absolute directory form ("/faq/"), got "${path}"`);
}
const isHome = path === "/";
if (isHome === (room !== undefined)) {
  throw new Error(
    isHome
      ? 'home is the atelier, not a room: pass no room for path "/"'
      : `every room page must name its room (got none for "${path}")`,
  );
}

const HOME_TITLE = "Vellum · an atelier of imaginary cartography";
const title = room ? `${room} · Vellum` : HOME_TITLE;
const ogTitle = ogRoom ? `${ogRoom} · Vellum` : title;
const ogUrl = new URL(path, Astro.site).href;
const ogImage = new URL("/og.png", Astro.site).href;
const ogImageAlt = "A Vellum antique chart beside the Vellum wordmark.";
const cardDescription = ogDescription ?? description;
---

<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{title}</title>
<meta name="description" content={description}>
<link rel="icon" type="image/svg+xml" href="/favicon.svg">
<meta property="og:type" content="website">
<meta property="og:site_name" content="Vellum">
<meta property="og:url" content={ogUrl}>
<meta property="og:title" content={ogTitle}>
<meta property="og:description" content={cardDescription}>
<meta property="og:image" content={ogImage}>
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<meta property="og:image:alt" content={ogImageAlt}>
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content={ogTitle}>
<meta name="twitter:description" content={cardDescription}>
<meta name="twitter:image" content={ogImage}>
<meta name="twitter:image:alt" content={ogImageAlt}>
<link rel="stylesheet" href="/fonts.css">
<link rel="stylesheet" href="/motion.css">
<link rel="stylesheet" href="index.css">
<style is:global>
/* The shell dresses once (#263), part B: the recurring parchment/ink palette,
   named here and consumed as var() by the page css files. The old body-text
   and voyage-track near-miss inks merged into --ink-dark at the PR #269
   review (item 4) and are retired. The charts' own label ink stays the
   renderer's (byte-identity domain), so site prose and chart lettering are
   deliberately no longer the same hex. Guarded by test/site/shell-css.test.ts. */
:root {
  --ink-dark: #4a3826;         /* dark walnut ink: borders, buttons, prose, emphasis */
  --ink-brown: #6b5a40;        /* flourish brown: taglines, captions, asides */
  --ink-faded: #857257;        /* faded ink: nav, footer, small labels */
  --line-tan: #b9a77f;         /* pale tan hairline: rules and frame borders */
  --parchment: #efe6cf;        /* the page ground every sheet rests on */
  --parchment-panel: #f4ecd8;  /* raised panels, cards, and pinned slips */
  --parchment-bright: #fff7e4; /* the lit cream: hovers and the reveal */
  --parchment-deep: #e6d9b8;   /* the pressed tan: code chips */
  --line-faint: #cdbd97;       /* the softer hairline, a shade lighter than --line-tan */
}
/* The shell dresses once (#263), part A: the rules every page shell shares.
   Per-page values stay in the page files: body padding and line-height, main
   max-width, header margin-bottom, footer margin-top. Since #268 the header
   is the Running Head, identical on every page (home keeps only its grander
   footer, pinned in public/index.css ABOVE this block's specificity because
   the page css link renders before this inline style). */
:root { color-scheme: light; }
body {
  margin: 0;
  background: var(--parchment); color: var(--ink-dark);
  font-family: var(--font-body, 'Iowan Old Style', 'Palatino', Georgia, serif);
}
main { margin-inline: auto; }
header { text-align: center; }
/* The Punchcutter's Case (#228) roles on the shell members: display for the
   wordmark, room name, nav band, and footer; flourish for the tagline. Page
   files keep their page-specific members. */
h1, .room-name, .topnav, footer {
  font-family: var(--font-display, 'Iowan Old Style', 'Palatino', Georgia, serif);
}
/* The Running Head (#268): the page header of an old folio. Left, the wordmark,
   the one place tracking opens up (Fell falls apart tracked out at text sizes);
   right, the room name with its tagline beneath, baseline-aligned so Fell's
   irregular x-height cannot float it; beneath both, the double hairline rule
   of an old ledger; then the nav band, centered. */
.running-head { display: flex; justify-content: space-between; align-items: baseline;
  gap: 0.5rem 2rem; text-align: left; }
h1 { font-size: 1.75rem; letter-spacing: 0.3em; margin: 0; }
h1 a { color: inherit; text-decoration: none; }
.room { text-align: right; }
.room-name { font-size: 1rem; letter-spacing: 0.07em; margin: 0; }
.tagline {
  font-family: var(--font-flourish, 'Iowan Old Style', 'Palatino', Georgia, serif);
  font-style: italic; color: var(--ink-brown); margin: 0.15rem 0 0;
}
.head-rule { height: 3px; border-top: 1px solid var(--ink-dark);
  border-bottom: 1px solid var(--ink-dark); margin: 0.7rem 0 0; }
@media (max-width: 480px) {
  /* The longer room names collide with the wordmark on a narrow sheet: stack
     the head centered. The negative margin recenters the wordmark over its
     trailing letter-space. */
  .running-head { flex-direction: column; align-items: center; gap: 0.2rem; text-align: center; }
  h1 { margin-right: -0.3em; }
  .room { text-align: center; }
}
.topnav { font-size: 0.82rem; letter-spacing: 0.12em; color: var(--ink-faded); margin: 0.9rem 0 0; }
/* motion.css makes nav LINKS inline-block so a multi-word label never wraps
   mid-label; the current page renders as a span, so it takes the same rule.
   Ink-dark + manicule + underline: the you-are-here marker never relies on
   color alone (#268). */
.topnav [aria-current="page"] { display: inline-block; color: var(--ink-dark);
  text-decoration: underline; text-underline-offset: 0.45em; text-decoration-thickness: 1px; }
.topnav a { color: inherit; }
/* The manicule's glyph coverage is inconsistent across the Fell fallback
   stack: pin the plain serif stack and let the system substitute, never the
   display role. */
.manicule { font-family: 'Iowan Old Style', 'Palatino', Georgia, serif; }
footer { text-align: center; font-size: 0.72rem; letter-spacing: 0.22em; color: var(--ink-faded); }
footer a { color: inherit; }
</style>
</head>
<body>
<main>
<header>
  <div class="running-head">
    <h1><a href="/">VELLUM</a></h1>
    <div class="room">
      {room && <p class="room-name">{room}</p>}
      <p class="tagline">{tagline}</p>
    </div>
  </div>
  <div class="head-rule"></div>
  <nav class="topnav">
    {NAV_ITEMS.map((item, i) => (
      <Fragment>{i > 0 ? " · " : ""}{item.href === path ? (
        <span aria-current="page"><span class="manicule" aria-hidden="true">☞&nbsp;</span>{item.label}</span>
      ) : (
        <a href={item.href}>{item.label}</a>
      )}</Fragment>
    ))}
  </nav>
  <slot name="header-extra" />
</header>

<slot />

<footer>
  VELLUM · AN ATELIER OF IMAGINARY CARTOGRAPHY
</footer>
</main>
</body>
</html>
