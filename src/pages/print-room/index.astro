---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  room="The Print Room"
  description="The atelier's print room: bring a world in from the Explorer or call up a seed by number, pull a proof, and take the chart home."
  path="/print-room/"
  tagline="take a world home"
>

<p class="intro">This is the atelier's print room, where a world leaves the screen
for the page. Bring a chart in from the Explorer, or call up a seed by number, and
pull a proof to see how it sits on paper.</p>

<div class="counter" role="group" aria-label="Choose a world">
  <label>seed <input id="pr-seed" type="number" min="0" max="4294967295" step="1"></label>
  <button id="pr-random" title="random seed" aria-label="Random seed">🎲</button>
  <label>style
    <select id="pr-style">
      <option value="antique" selected>antique</option>
      <option value="topographic">topographic</option>
      <option value="ink">ink</option>
      <option value="nautical">nautical</option>
    </select>
  </label>
  <button id="pr-draw" class="primary">Pull a proof</button>
</div>

<p id="pr-warning" class="warning" hidden>Your browser could not start the render
worker, so proofs are drawn on the main thread. A large plate may pause the page for
a moment.</p>

<!-- The order desk sits ABOVE the proof (#136 redesign): all the deciding happens here in
     two side-by-side offerings; everything below the desk is pure output, the proof and, once
     bound, the atlas. -->
<section class="order-desk" aria-labelledby="pr-desk-head">
  <h2 class="desk-head" id="pr-desk-head">Take this world home</h2>
  <div class="offerings">
    <div class="offering" aria-labelledby="pr-plate-head">
      <h3 class="offering-head" id="pr-plate-head">A poster plate</h3>
      <p class="offering-intro">One chart, pulled poster-wide and handed to you to send to a printer.</p>
      <div class="offering-controls">
        <label class="offering-field" for="pr-format">Pressed as
          <select id="pr-format">
            <option value="svg" selected>Vector (SVG)</option>
            <option value="png1">Image (PNG &times;1)</option>
            <option value="png2">Image (PNG &times;2)</option>
          </select>
        </label>
        <div class="plate-row" role="group" aria-label="Plate size">
          <button class="plate" data-poster="desk" disabled>Desk<span class="plate-dim">2400 px</span></button>
          <button class="plate" data-poster="wall" disabled>Wall<span class="plate-dim">3300 px</span></button>
          <button class="plate" data-poster="grand" disabled>Grand<span class="plate-dim">4200 px</span></button>
        </div>
      </div>
      <p class="offering-caveat">A PNG uses your device's fonts; keep the vector SVG for an exact
      copy. A large image is fitted to what your browser can hold.</p>
      <p class="status" id="pr-poster-status" role="status" aria-live="polite"></p>
    </div>

    <div class="offering" aria-labelledby="pr-atlas-head">
      <h3 class="offering-head" id="pr-atlas-head">The bound atlas</h3>
      <p class="offering-intro">The whole atlas on one sheet: every draughting, the thematic and
      regional surveys, the banners, the chronicle, and the gazetteer.</p>
      <div class="offering-controls">
        <button id="pr-bind" class="primary" disabled>Bind the atlas</button>
        <div class="atlas-actions" role="group" aria-label="Bound atlas">
          <button id="pr-print" disabled>Print</button>
          <button id="pr-download" disabled>Download</button>
          <button id="pr-hide" disabled>Hide</button>
        </div>
      </div>
      <p class="offering-caveat">Print opens your browser's Save as PDF, one plate per page. The
      single file is about 20 MB and opens offline.</p>
      <p class="status" id="pr-bound-status" role="status" aria-live="polite"></p>
    </div>
  </div>
</section>

<p class="status" id="pr-status" role="status" aria-live="polite"></p>
<div id="pr-preview" class="preview"></div>
<p class="caption" id="pr-caption"></p>

<!-- The bound atlas populates here, below the proof. On screen it omits the header + hero
     (already shown as the proof above); print + download restore the full atlas. -->
<div id="pr-atlas" class="atlas-sheet"></div>

<script type="module" src="./app.bundle.js" is:inline></script>
</BaseLayout>
