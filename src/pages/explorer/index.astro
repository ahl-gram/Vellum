---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  room="The Explorer"
  description="Generate procedural fantasy maps in your browser. Every seed is a world."
  path="/explorer/"
  tagline="every seed is a world, draw one"
>

<div class="controls">
  <div class="control-row" role="group" aria-labelledby="grp-map">
    <span class="row-label" id="grp-map">Map</span>
    <div class="row-fields">
      <label>seed <input id="seed" type="number" min="0" max="4294967295" step="1"></label>
      <button id="random" title="random seed" aria-label="Random seed">🎲</button>
      <label>style
        <select id="style">
          <option value="antique" selected>antique</option>
          <option value="topographic">topographic</option>
          <option value="ink">ink</option>
          <option value="nautical">nautical</option>
        </select>
      </label>
      <label>type
        <select id="type">
          <option value="" selected>seed's choice</option>
          <option value="island">island</option>
          <option value="archipelago">archipelago</option>
          <option value="continent">continent</option>
          <option value="citystate">city-state</option>
        </select>
      </label>
      <label>climate
        <select id="band">
          <option value="" selected>seed's choice</option>
          <option value="temperate">temperate</option>
          <option value="tropical">tropical</option>
          <option value="polar">polar</option>
        </select>
      </label>
    </div>
  </div>
  <div class="control-row" role="group" aria-labelledby="grp-display">
    <span class="row-label" id="grp-display">Display</span>
    <div class="row-fields">
      <label>theme
        <select id="theme">
          <option value="" selected>none</option>
          <option value="vegetation">vegetation</option>
          <option value="climate">temperature</option>
          <option value="moisture">rainfall</option>
          <option value="population">population</option>
        </select>
      </label>
      <label class="check">legend <input id="legend" type="checkbox" checked></label>
      <label class="check">arms <input id="arms" type="checkbox"></label>
      <label class="check">chronicle <input id="chronicle" type="checkbox"></label>
      <label class="check">voyage <input id="voyage" type="checkbox"></label>
      <label class="sealevel">sea level
        <span class="land-end">more sea</span>
        <input id="land" type="range" min="100" max="700" step="2" aria-label="Sea level">
        <span class="land-end">more land</span>
        <span id="land-readout" class="land-readout"></span>
      </label>
      <label class="sealevel">coast
        <span class="land-end">calm</span>
        <input id="coast" type="range" min="0" max="100" step="5" aria-label="Coastline warp">
        <span class="land-end">lobed</span>
        <span id="coast-readout" class="land-readout"></span>
      </label>
    </div>
  </div>
  <div class="control-row" role="group" aria-labelledby="grp-actions">
    <span class="row-label" id="grp-actions">Actions</span>
    <div class="row-fields">
      <button id="draw" class="primary">Draw</button>
      <button id="download">Download SVG</button>
      <button id="verso-turn">Turn the sheet</button>
      <!-- #133: carry the world on screen to the Print Room. Its href is refreshed on
           every draw (app.js) so it always carries the CURRENT hash, not the load-time one.
           #199: now the Explorer's only path to the bound atlas, so it is the featured
           "take your world home" action (see .action-link in index.css). The glyph is
           decorative, so aria-hidden keeps the link's accessible name clean. -->
      <a id="order-plates" class="action-link" href="../print-room/"><svg class="order-glyph" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><!-- #199: a freshly pulled proof (the Print Room "pulls a proof"): a dog-eared printed sheet under the press platen, whose turn-handle offsets to one side. Paper is the hero and the whole thing is asymmetric on purpose, so it reads as paper rather than a symmetric mark. Decorative (aria-hidden); the link text carries the meaning. --><path d="M4 6.5h13.5"/><circle cx="4" cy="6.5" r="1.4"/><path d="M7 9h6l3.5 3.5V20.5H7z"/><path d="M13 9v3.5h3.5"/><path d="M9.5 15h4.5M9.5 17.5h3"/></svg>Take to the Print Room</a>
    </div>
  </div>
</div>

<p class="status" id="status" role="status" aria-live="polite"></p>
<!-- #131: the sheet wrapper. #map is the recto (the live chart); a style change
     turns this leaf over (sheet-turn.js) to land the same world re-dressed. The 3D
     context is inert until .turning is set, so idle behaviour is unchanged. Never
     restructure INSIDE #map: draw() wipes it with innerHTML and re-appends the
     overlay right after.
     #116: #verso is the recto's back face, a permanent sibling of #map filled by
     verso.js. It rests hidden (visibility gated on .flip3d) so idle byte-parity
     holds; the Turn button flips the whole leaf 180deg to read it. -->
<div class="sheet" id="sheet"><div class="sheet-inner" id="sheet-inner">
<!-- #164 The Surveyor's Glass: #map-viewport is the clipping/gesture box the shared
     zoom-controller (src/site/shared/zoom-controller.ts) binds to; the live CSS transform
     lands on #map inside it, so the chart SVG and its %-positioned overlays (place
     hits, cards, voyage track) ride one frame. It sits between #sheet-inner and #map
     so #sheet-inner's rotateY (the #131 turn / #116 verso) gains no third claimant;
     the backface-visibility rules that used to name #map now name #map-viewport (its
     direct child in the preserve-3d context). #verso stays a SIBLING outside it. -->
<div id="map-viewport" tabindex="0" role="application" aria-label="Interactive map. Arrow keys pan, plus and minus keys zoom, 0 resets."><div id="map"></div>
<!-- #165 The Surveyor's Glass: the on-screen zoom cluster. A SIBLING of #map (never inside
     it), so it does NOT ride #map's live zoom transform; it sits in the viewport corner and
     is clipped in-bounds by .zoomed's overflow. VOICED in #170: the group and its controls
     speak in the antique voice (Lean closer / The full sheet / Stand back), each aria-label
     keeping the plain function in parentheses so AT users get both the voice and the verb.
     The glyphs are drawn line-art in the cluster's own ink (stroke=currentColor, the house
     and order-glyph precedent): a surveyor's hand lens leaning in and standing back, and a
     dog-eared chart sheet for the full-sheet return (the house it replaces said "home", but
     this control returns THE SHEET, and the cluster is the Surveyor's Glass).
     The buttons plus the focusable viewport (arrow-pan) meet the keyboard-only hard
     requirement; the keys legend below is Sub 4's handoff resolved (Alex's call: a small
     visible slip, the only form a sighted mouse user can discover without hover). It is
     aria-hidden because the viewport's aria-label already announces the same keys. -->
<div id="zoom-controls" class="zoom-controls" role="group" aria-label="The Surveyor's Glass">
  <button id="zoom-in" type="button" aria-label="Lean closer (zoom in)" title="Lean closer"><svg aria-hidden="true" width="15" height="15" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><circle cx="6.8" cy="6.8" r="4.2"/><path d="M9.9 9.9l3.7 3.7"/><path d="M6.8 4.9v3.8M4.9 6.8h3.8"/></svg></button>
  <button id="zoom-reset" type="button" aria-label="The full sheet (reset the view)" title="The full sheet"><svg aria-hidden="true" width="15" height="15" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M3.4 2.6h6.6l2.6 2.6v8.2H3.4z"/><path d="M10 2.6v2.6h2.6"/><path d="M5.3 9.7c1-.9 1.9.5 2.9-.3.8-.7 1.5-.2 2.2-.7"/></svg></button>
  <button id="zoom-out" type="button" aria-label="Stand back (zoom out)" title="Stand back"><svg aria-hidden="true" width="15" height="15" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><circle cx="6.8" cy="6.8" r="4.2"/><path d="M9.9 9.9l3.7 3.7"/><path d="M4.9 6.8h3.8"/></svg></button>
  <div class="zoom-keys" aria-hidden="true">
    <span><kbd>+</kbd> <kbd>&#8722;</kbd> lean closer, stand back</span>
    <span><kbd>&#8592;&#8593;&#8594;&#8595;</kbd> pan the sheet</span>
    <span><kbd>0</kbd> the full sheet</span>
  </div>
</div>
</div>
<div id="verso" aria-hidden="true"></div>
</div></div>
<p class="caption" id="caption"></p>
<div id="scrubber" class="scrubber" hidden>
  <div class="scrub-controls">
    <button id="scrub-play" type="button">Play</button>
    <input id="scrub-range" type="range" aria-label="Chronicle year">
    <span id="scrub-year" class="scrub-year" aria-hidden="true"></span>
  </div>
  <ol id="chronicle-strip" class="chronicle-strip"></ol>
</div>
<!-- #121 The margin log: the surveyor's dated journal, one entry per port, revealed as
     the survey reaches each. A voyage-only panel styled like the chronicle strip but its
     own element (voyage and chronicle are mutually exclusive). The overlay <svg> is
     aria-hidden; this readable list plus the one polite #status summary carry the a11y. -->
<div id="voyage-log" class="voyage-log" hidden role="region" aria-label="The surveyor's log">
  <p id="voyage-log-sig" class="voyage-log-sig"></p>
  <ol id="voyage-log-strip" class="voyage-log-strip"></ol>
</div>

<script type="module" src="./app.bundle.js" is:inline></script>
</BaseLayout>
