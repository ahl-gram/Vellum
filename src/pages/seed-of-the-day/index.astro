---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Vellum: the seed of the day"
  description="A new procedural world every day: today's date is the seed, drawn as an antique chart with a line from its gazetteer. Same day, same world, everywhere."
  ogTitle="Vellum: the seed of the day"
  ogDescription="A new procedural world every day: today's date is the seed, drawn as an antique chart with a line from its gazetteer."
  path="/seed-of-the-day/"
  tagline="the seed of the day"
>

<p class="dateline" id="dateline"></p>
<p class="status" id="status">Drafting today's world&hellip;</p>

<div class="stage">
  <figure>
    <!-- #167 The Surveyor's Glass, Sub 6: #map-viewport is the stable clip/gesture box
         the shared zoom-controller (src/site/shared/zoom-controller.ts) binds to; the live
         CSS transform lands on #map inside it, so the chart SVG and its %-positioned
         overlays (the hunt star, the miss soundings) ride one composited frame. The
         figcaption (the world's name) stays OUTSIDE the frame, and the clue list is a
         sibling of the whole figure, so neither magnifies with the sheet. -->
    <div id="map-viewport"><div id="map"></div></div>
    <figcaption id="caption"></figcaption>
  </figure>

  <section class="hunt" id="hunt" hidden>
    <h2>The Daily Hunt</h2>
    <p class="hunt-intro">One forgotten place hides on today's chart. Read the
    survey notes, then click the map to find it. Everyone hunting today's seed is
    looking for the same place.</p>
    <ol class="clues" id="clues"></ol>
    <p class="hunt-status" id="hunt-status" aria-live="polite"></p>
    <div class="reveal" id="reveal" hidden></div>
    <div class="hunt-actions">
      <button type="button" id="share" hidden>Share your find</button>
      <button type="button" id="dispatch" hidden>Draft dispatch</button>
      <span class="streak" id="streak"></span>
    </div>
    <p class="note">Your streak is kept on this device only: no account, no
    backend.</p>
  </section>
</div>

<p class="survey" id="survey"></p>
<p class="blurb" id="blurb"></p>

<div id="hunt-sticky" class="hunt-sticky" aria-hidden="true" hidden></div>

<div class="actions">
  <a id="explore" href="../explorer/">Open today's seed in the Explorer</a>
</div>

<p class="note">The seed is today's date in UTC (YYYYMMDD), so everyone sees the
same world on the same day. Come back tomorrow for a new one.</p>

<noscript>
  <p class="note">Today's world is drawn in your browser, so this page needs
  JavaScript. You can still <a href="../explorer/">draw any seed in the
  Explorer</a> or browse the <a href="../gallery/">gallery</a>.</p>
</noscript>

<script type="module" src="app.bundle.js" is:inline></script>
</BaseLayout>
