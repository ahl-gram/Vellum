---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { GALLERY_COUNT, GALLERY_SEED, cardFigureHtml, galleryCards } from "../../cli/gallery.ts";

// The contact sheet is composed at build time from the same deterministic
// composer generate-showcases renders the SVGs with, so the two runs always
// agree on worlds and filenames. The figure markup is the old standalone
// gallery's, adopted unchanged (#268).
const figures = galleryCards(GALLERY_SEED, GALLERY_COUNT).map(cardFigureHtml).join("\n");
---

<BaseLayout
  room="The Gallery"
  description="A contact sheet of twelve imaginary worlds, drawn by Vellum as antique charts and hung for viewing."
  path="/gallery/"
  tagline="a dozen worlds, hung for viewing"
>
<p class="sub">{GALLERY_COUNT} charts drawn by Vellum, beginning at seed {GALLERY_SEED}</p>
<div class="grid" set:html={figures}></div>
</BaseLayout>
