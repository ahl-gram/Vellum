{
  "name": "vellum",
  "version": "0.1.0",
  "description": "An atelier of imaginary cartography — procedurally surveys worlds that don't exist and drafts them as antique atlas charts.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "chart": "node src/cli/main.ts chart",
    "dev": "npm run astro:dev",
    "og": "node scripts/build-og.ts",
    "charts:regen": "node scripts/regen-hero-charts.ts",
    "astro:generate": "node scripts/clean-public-generated.ts && node scripts/build-app-bundles.ts && node scripts/generate-showcases.ts",
    "astro:dev": "npm run astro:generate && astro dev",
    "astro:preview": "astro preview",
    "build": "npm run astro:generate && astro build",
    "test": "node --test",
    "test:e2e": "node scripts/e2e-explorer.mjs",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "d3-selection": "^3.0.0",
    "d3-transition": "^3.0.0",
    "d3-zoom": "^3.0.0"
  },
  "devDependencies": {
    "@types/d3-selection": "^3.0.11",
    "@types/d3-transition": "^3.0.9",
    "@types/d3-zoom": "^3.0.8",
    "@types/node": "^24.0.0",
    "astro": "^7.1.3",
    "typescript": "^5.8.0",
    "vite": "^8.0.13"
  }
}
